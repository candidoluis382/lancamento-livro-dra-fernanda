[{"id":11186,"slug":"luxury-law-firm-11","title":"Luxury Law Firm Landing Page Template","code":"<!DOCTYPE html>\n<html lang=\"pt-br\" class=\"scroll-smooth overflow-x-hidden\">\n<head>\n<script>\ntry{if(window.parent&&window.parent!==window){window.parent.promotekit_referral=\"1fd2949a-d22c-431b-92bf-02d4ad04ee24\";window.parent.document.cookie=\"promotekit_referral=1fd2949a-d22c-431b-92bf-02d4ad04ee24;path=/;domain=.aura.build;max-age=31536000\"}}catch(e){}\n</script>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Adekvat | Advocacia de Alta Performance</title>\n<!-- Fonts: Inter (Tech/Clean) & Instrument Serif (Luxury/Legal) -->\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Instrument+Serif:ital,wght@0,400;1,400&display=swap\" rel=\"stylesheet\">\n<!-- Tailwind CSS -->\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<!-- Iconify -->\n<script src=\"https://unpkg.com/lucide@latest\"></script>\n<script>\ntailwind.config = {\ntheme: {\nextend: {\nfontFamily: {\nsans: ['Inter', 'sans-serif'],\nserif: ['Instrument Serif', 'serif'],\n},\ncolors: {\nbrand: {\ngold: '#C4A470',\ngoldglow: '#D4B480',\ndark: '#020204',\npanel: '#0A0B10',\nborder: 'rgba(255,255,255,0.08)'\n}\n},\nanimation: {\n'float': 'float 8s ease-in-out infinite',\n'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',\n'marquee': 'marquee 40s linear infinite',\n},\nkeyframes: {\nfloat: {\n'0%, 100%': { transform: 'translateY(0)' },\n'50%': { transform: 'translateY(-10px)' },\n},\nmarquee: {\n'0%': { transform: 'translateX(0)' },\n'100%': { transform: 'translateX(-50%)' },\n}\n}\n}\n}\n}\n</script>\n<style>\nbody {\nbackground-color: #020204;\ncolor: #ffffff;\n-webkit-font-smoothing: antialiased;\noverflow-x: hidden;\n}\n/* --- Scroll Reveal --- */\n.reveal {\nopacity: 0;\ntransform: translateY(20px);\ntransition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);\nfilter: blur(4px);\n}\n.reveal.active {\nopacity: 1;\ntransform: translateY(0);\nfilter: blur(0);\n}\n/* --- Glassmorphism --- */\n.glass-panel {\nbackground: linear-gradient(180deg, rgba(196, 164, 112, 0.03) 0%, rgba(255,255,255,0.01) 100%);\nbackdrop-filter: blur(12px);\nborder: 1px solid rgba(255, 255, 255, 0.08);\nbox-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);\n}\n/* --- Background Grid --- */\n.bg-grid {\nbackground-size: 40px 40px;\nbackground-image: linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px),\nlinear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px);\nmask-image: radial-gradient(circle at center, black 40%, transparent 100%);\n}\n/* Custom Scrollbar */\n::-webkit-scrollbar { width: 6px; }\n::-webkit-scrollbar-track { background: #020204; }\n::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }\n::-webkit-scrollbar-thumb:hover { background: #444; }\n/* Text Gradients */\n.text-gradient {\nbackground: linear-gradient(to bottom right, #ffffff, #C4A470);\n-webkit-background-clip: text;\n-webkit-text-fill-color: transparent;\n}\n/* Custom Inputs */\n.tech-input {\nbackground: rgba(255,255,255,0.03);\nborder: 1px solid rgba(255,255,255,0.1);\ntransition: all 0.3s ease;\n}\n.tech-input:focus {\nbackground: rgba(196, 164, 112, 0.05);\nborder-color: #C4A470;\noutline: none;\nbox-shadow: 0 0 15px rgba(196, 164, 112, 0.1);\n}\n</style></head>\n<body class=\"relative min-h-screen selection:bg-brand-gold selection:text-brand-dark\">\n\n    <!-- Background Structure -->\n    <div class=\"fixed inset-0 pointer-events-none -z-10 bg-grid\"></div>\n    <div class=\"fixed top-0 left-1/2 -translate-x-1/2 w-[300px] md:w-[800px] h-[600px] bg-indigo-900/20 rounded-full blur-[80px] md:blur-[120px] -z-10\"></div>\n    <div class=\"fixed bottom-0 right-0 w-[400px] h-[400px] bg-brand-gold/5 rounded-full blur-[100px] -z-10\"></div>\n\n    <!-- Navigation -->\n    <nav class=\"fixed top-4 md:top-6 left-1/2 -translate-x-1/2 w-[95%] md:w-[92%] max-w-5xl z-50 transition-all duration-300\">\n        <div class=\"glass-panel rounded-full p-2 pl-4 md:pl-6 flex items-center justify-between shadow-2xl shadow-black/50\">\n            <div class=\"flex items-center gap-3\">\n                <div class=\"w-3 h-3 bg-brand-gold rounded-sm rotate-45 shadow-[0_0_12px_rgba(196,164,112,0.8)]\"></div>\n                <div class=\"flex flex-col\">\n                    <span class=\"text-sm font-serif tracking-wide text-white leading-none\">ADEKVAT</span>\n                    <span class=\"text-[8px] uppercase tracking-[0.2em] text-white/40 leading-none mt-0.5\">Jurídico Premium</span>\n                </div>\n            </div>\n            \n            <div class=\"hidden md:flex items-center gap-8\">\n                <a href=\"#atuacao\" class=\"text-xs font-normal text-white/60 hover:text-white transition-colors tracking-wide\">Atuação</a>\n                <a href=\"#sobre\" class=\"text-xs font-normal text-white/60 hover:text-white transition-colors tracking-wide\">O Escritório</a>\n                <a href=\"#equipe\" class=\"text-xs font-normal text-white/60 hover:text-white transition-colors tracking-wide\">Sócios</a>\n            </div>\n\n            <div class=\"flex items-center gap-3\">\n                <a href=\"#contato\" class=\"bg-white text-brand-dark px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-widest hover:bg-brand-gold hover:text-white transition-all duration-300 shadow-[0_0_15px_rgba(255,255,255,0.1)]\">\n                    Consultoria\n                </a>\n            </div>\n        </div>\n    </nav>\n\n    <main class=\"pt-32 md:pt-40 pb-20\">\n\n        <!-- Hero Section -->\n        <section class=\"container mx-auto px-6 max-w-6xl text-center mb-20 md:mb-32 relative\">\n            <div class=\"reveal active flex flex-col items-center\">\n                \n                <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-gold/20 bg-brand-gold/5 backdrop-blur-sm mb-8\">\n                    <span class=\"relative flex h-2 w-2\">\n                        <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 bg-brand-gold\"></span>\n                        <span class=\"relative inline-flex rounded-full h-2 w-2 bg-brand-gold\"></span>\n                    </span>\n                    <span class=\"text-[10px] font-medium text-brand-gold tracking-widest uppercase\">Est. 2005 • São Paulo</span>\n                </div>\n\n                <h1 class=\"text-5xl sm:text-6xl md:text-8xl font-serif text-white tracking-tight leading-[0.95] mb-8\">\n                    Defesa <br class=\"hidden md:block\" />\n                    <span class=\"text-white/40 italic pr-2\">Estratégica</span>\n                    <span class=\"text-gradient\">Absoluta.</span>\n                </h1>\n\n                <div class=\"h-px w-32 bg-gradient-to-r from-transparent via-brand-gold/50 to-transparent mb-8\"></div>\n\n                <p class=\"text-base md:text-xl font-light text-white/50 max-w-2xl leading-relaxed mb-10 mx-auto\">\n                    Advocacia artesanal para casos de alta complexidade. Quando o resultado define o futuro do seu patrimônio.\n                </p>\n\n                <div class=\"flex flex-col sm:flex-row items-center gap-4 w-full justify-center px-4\">\n                    <a href=\"#atuacao\" class=\"group relative inline-flex items-center justify-center overflow-hidden rounded-full p-[1px] focus:outline-none\">\n                        <span class=\"absolute inset-[-1000%] animate-[spin_4s_linear_infinite] bg-[conic-gradient(from_90deg_at_50%_50%,#020402_0%,#C4A470_50%,#020402_100%)]\"></span>\n                        <span class=\"inline-flex h-full w-full cursor-pointer items-center justify-center gap-3 rounded-full bg-brand-panel px-8 py-3.5 text-xs font-bold uppercase tracking-widest text-white backdrop-blur-3xl transition-all group-hover:bg-[#151515]\">\n                            Conheça nossa expertise\n                            <i data-lucide=\"arrow-down\" class=\"w-4 h-4 text-brand-gold group-hover:translate-y-0.5 transition-transform\"></i>\n                        </span>\n                    </a>\n                </div>\n            </div>\n        </section>\n\n        <!-- Stats / Authority Strip (Glassmorphism) -->\n        <section class=\"container mx-auto px-4 max-w-7xl mb-32 reveal\">\n            <div class=\"grid grid-cols-1 md:grid-cols-4 gap-4\">\n                <!-- Stat 1 -->\n                <div class=\"glass-panel p-6 rounded-xl border border-white/5 hover:border-brand-gold/30 transition-colors group\">\n                    <div class=\"flex items-center gap-3 mb-2\">\n                        <div class=\"p-2 rounded-md bg-brand-gold/10 text-brand-gold\">\n                            <i data-lucide=\"shield-check\" class=\"w-5 h-5\"></i>\n                        </div>\n                        <span class=\"text-[10px] uppercase tracking-widest text-white/40 group-hover:text-brand-gold transition-colors\">Patrimônio</span>\n                    </div>\n                    <span class=\"block font-serif text-3xl text-white\">R$ 500M+</span>\n                    <span class=\"text-[10px] text-white/30\">Preservado em litígios</span>\n                </div>\n\n                <!-- Stat 2 -->\n                <div class=\"glass-panel p-6 rounded-xl border border-white/5 hover:border-brand-gold/30 transition-colors group\">\n                    <div class=\"flex items-center gap-3 mb-2\">\n                        <div class=\"p-2 rounded-md bg-brand-gold/10 text-brand-gold\">\n                            <i data-lucide=\"hourglass\" class=\"w-5 h-5\"></i>\n                        </div>\n                        <span class=\"text-[10px] uppercase tracking-widest text-white/40 group-hover:text-brand-gold transition-colors\">Tradição</span>\n                    </div>\n                    <span class=\"block font-serif text-3xl text-white\">20 Anos</span>\n                    <span class=\"text-[10px] text-white/30\">Excelência jurídica</span>\n                </div>\n\n                <!-- Stat 3 -->\n                <div class=\"glass-panel p-6 rounded-xl border border-white/5 hover:border-brand-gold/30 transition-colors group\">\n                    <div class=\"flex items-center gap-3 mb-2\">\n                        <div class=\"p-2 rounded-md bg-brand-gold/10 text-brand-gold\">\n                            <i data-lucide=\"layers\" class=\"w-5 h-5\"></i>\n                        </div>\n                        <span class=\"text-[10px] uppercase tracking-widest text-white/40 group-hover:text-brand-gold transition-colors\">Atuação</span>\n                    </div>\n                    <span class=\"block font-serif text-3xl text-white\">Full Service</span>\n                    <span class=\"text-[10px] text-white/30\">Integração total</span>\n                </div>\n\n                <!-- Stat 4 -->\n                <div class=\"glass-panel p-6 rounded-xl border border-white/5 hover:border-brand-gold/30 transition-colors group\">\n                    <div class=\"flex items-center gap-3 mb-2\">\n                        <div class=\"p-2 rounded-md bg-brand-gold/10 text-brand-gold\">\n                            <i data-lucide=\"award\" class=\"w-5 h-5\"></i>\n                        </div>\n                        <span class=\"text-[10px] uppercase tracking-widest text-white/40 group-hover:text-brand-gold transition-colors\">Certificação</span>\n                    </div>\n                    <span class=\"block font-serif text-3xl text-white\">ISO 9001</span>\n                    <span class=\"text-[10px] text-white/30\">Processos auditados</span>\n                </div>\n            </div>\n        </section>\n\n        <!-- Services Bento Grid -->\n        <section id=\"atuacao\" class=\"container mx-auto px-6 max-w-6xl mb-32\">\n            <div class=\"mb-16 md:text-center max-w-2xl mx-auto reveal\">\n                <span class=\"text-brand-gold text-[10px] tracking-[0.25em] uppercase font-bold mb-4 block\">Áreas de Atuação</span>\n                <h2 class=\"text-3xl md:text-5xl font-serif text-white tracking-tight mb-6\">Jurídico sob medida <br><span class=\"italic text-white/40\">para o seu legado.</span></h2>\n                <p class=\"text-white/50 font-light leading-relaxed\">\n                    Não acreditamos em soluções de prateleira. Cada estratégia é desenhada exclusivamente para o cenário do cliente, combinando profundidade técnica e visão de negócios.\n                </p>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[minmax(300px,auto)]\">\n                \n                <!-- Service 1: Large Card (Contencioso) -->\n                <div class=\"md:col-span-2 rounded-3xl glass-panel p-8 md:p-10 relative overflow-hidden group reveal hover:bg-white/[0.02] transition-colors\">\n                    <div class=\"absolute top-0 right-0 w-96 h-96 bg-brand-gold/5 blur-[80px] rounded-full pointer-events-none transition-opacity opacity-50 group-hover:opacity-100\"></div>\n                    \n                    <div class=\"relative z-10 flex flex-col h-full justify-between\">\n                        <div class=\"mb-8\">\n                            <div class=\"w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center mb-6 text-brand-gold\">\n                                <i data-lucide=\"gavel\" class=\"w-6 h-6\"></i>\n                            </div>\n                            <h3 class=\"text-3xl font-serif text-white mb-3\">Contencioso Cível</h3>\n                            <p class=\"text-white/50 text-sm font-light leading-relaxed max-w-md\">\n                                Resolução de disputas complexas, arbitragem e mediação com foco na preservação de valor. Estratégia processual cirúrgica.\n                            </p>\n                        </div>\n\n                        <!-- Visual: Timeline/Progress -->\n                        <div class=\"w-full relative border-t border-white/10 mt-4 pt-6\">\n                            <div class=\"flex justify-between items-center text-[10px] text-white/30 uppercase tracking-widest font-mono mb-2\">\n                                <span>Início</span>\n                                <span class=\"text-brand-gold\">Sentença Favorável</span>\n                            </div>\n                            <div class=\"w-full h-1 bg-white/10 rounded-full overflow-hidden\">\n                                <div class=\"h-full bg-gradient-to-r from-brand-gold/20 via-brand-gold to-brand-gold w-[85%] relative\">\n                                    <div class=\"absolute right-0 top-1/2 -translate-y-1/2 w-2 h-2 bg-white rounded-full shadow-[0_0_10px_white]\"></div>\n                                </div>\n                            </div>\n                            <div class=\"mt-4 flex gap-4\">\n                                <div class=\"bg-black/40 border border-white/10 px-3 py-2 rounded text-[10px] text-white/60 font-mono\">\n                                    DOC_REF: <span class=\"text-white\">LIMINAR_DEFERIDA</span>\n                                </div>\n                                <div class=\"bg-black/40 border border-white/10 px-3 py-2 rounded text-[10px] text-white/60 font-mono\">\n                                    STATUS: <span class=\"text-green-400\">ATIVO</span>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Service 2: Vertical (Empresarial) -->\n                <div class=\"md:col-span-1 rounded-3xl glass-panel p-8 relative overflow-hidden group reveal delay-100\">\n                    <div class=\"absolute inset-0 bg-gradient-to-b from-white/[0.02] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500\"></div>\n                    \n                    <div class=\"w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center mb-6 text-brand-gold\">\n                        <i data-lucide=\"building-2\" class=\"w-6 h-6\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-serif text-white mb-2\">Direito Empresarial</h3>\n                    <p class=\"text-white/50 text-sm font-light mb-8\">\n                        Assessoria em contratos, M&A, governança corporativa e estruturação societária.\n                    </p>\n\n                    <!-- Mock Contract List -->\n                    <div class=\"bg-brand-dark/50 rounded-lg p-4 border border-white/5 transform group-hover:scale-105 transition-transform duration-500\">\n                        <div class=\"flex flex-col gap-3\">\n                            <div class=\"flex items-center gap-3 text-[10px] text-white/60 font-mono border-b border-white/5 pb-2\">\n                                <i data-lucide=\"file-check\" class=\"w-3 h-3 text-brand-gold\"></i>\n                                <span>Contrato Social.pdf</span>\n                            </div>\n                            <div class=\"flex items-center gap-3 text-[10px] text-white/60 font-mono border-b border-white/5 pb-2\">\n                                <i data-lucide=\"file-check\" class=\"w-3 h-3 text-brand-gold\"></i>\n                                <span>Acordo Sócios.pdf</span>\n                            </div>\n                            <div class=\"flex items-center gap-3 text-[10px] text-white/60 font-mono\">\n                                <i data-lucide=\"file-check\" class=\"w-3 h-3 text-brand-gold\"></i>\n                                <span>Compliance.docx</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Service 3: Interactive (Sucessão) -->\n                <div class=\"md:col-span-1 rounded-3xl glass-panel p-8 relative overflow-hidden group reveal delay-100\">\n                    <div class=\"absolute -bottom-10 -right-10 w-40 h-40 bg-brand-gold/10 blur-[60px] rounded-full\"></div>\n                    \n                    <div class=\"w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center mb-6 text-brand-gold\">\n                        <i data-lucide=\"scroll\" class=\"w-6 h-6\"></i>\n                    </div>\n                    <h3 class=\"text-2xl font-serif text-white mb-2\">Sucessão Patrimonial</h3>\n                    <p class=\"text-white/50 text-sm font-light mb-8\">\n                        Holdings familiares e proteção de ativos para as próximas gerações.\n                    </p>\n\n                    <div class=\"relative h-24\">\n                        <div class=\"absolute inset-0 flex flex-col gap-3\">\n                            <!-- Toggle Mockup -->\n                            <div class=\"relative w-full bg-brand-dark/50 rounded-xl p-3 flex items-center justify-between border border-brand-gold/20 shadow-[0_0_15px_rgba(196,164,112,0.1)]\">\n                                <span class=\"text-xs text-white/80 font-medium\">Blindagem</span>\n                                <div class=\"flex items-center gap-2\">\n                                    <span class=\"text-[9px] text-brand-gold uppercase tracking-wider\">Ativada</span>\n                                    <div class=\"w-8 h-4 bg-brand-gold rounded-full relative\">\n                                        <div class=\"absolute right-0.5 top-0.5 w-3 h-3 bg-white rounded-full\"></div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Card 4: Stats/Quote -->\n                <div class=\"md:col-span-2 rounded-3xl glass-panel p-8 md:p-10 relative overflow-hidden group reveal\">\n                    <div class=\"flex flex-col md:flex-row justify-between items-center gap-8 h-full\">\n                        <div class=\"max-w-md\">\n                            <i data-lucide=\"quote\" class=\"w-8 h-8 text-brand-gold mb-6 fill-brand-gold/20\"></i>\n                            <p class=\"font-serif text-xl md:text-2xl text-white italic mb-6 leading-relaxed\">\n                                \"A excelência não é um ato, mas um hábito. Nossa obsessão é a perfeição técnica em cada detalhe do processo.\"\n                            </p>\n                            <div class=\"flex items-center gap-4\">\n                                <div class=\"h-px w-12 bg-white/20\"></div>\n                                <span class=\"text-[10px] uppercase tracking-widest text-white/40 font-bold\">Dr. Roberto Adekvat, Sócio Fundador</span>\n                            </div>\n                        </div>\n                        \n                        <!-- Citation Visual -->\n                        <div class=\"hidden md:block w-[240px] bg-[#0A0A0A] border border-white/10 rounded-xl p-6 font-serif text-center shadow-2xl relative rotate-3 group-hover:rotate-0 transition-transform duration-500\">\n                            <div class=\"w-full h-px bg-white/10 mb-4\"></div>\n                            <h4 class=\"text-brand-gold text-lg\">OAB/SP 00.000</h4>\n                            <p class=\"text-xs text-white/40 mt-2\">Inscrito desde 2005</p>\n                            <div class=\"mt-6 flex justify-center\">\n                                <i data-lucide=\"feather\" class=\"w-8 h-8 text-white/20\"></i>\n                            </div>\n                            <div class=\"absolute -inset-1 bg-gradient-to-r from-brand-gold/20 to-transparent blur opacity-20 -z-10\"></div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- Dynamic Visualization (Replaced with Legal Protection Metaphor) -->\n        <section class=\"py-20 md:py-32 relative overflow-hidden border-y border-white/5\">\n            <div class=\"absolute inset-0 bg-brand-dark opacity-90\"></div>\n            <div class=\"container mx-auto px-6 max-w-4xl text-center relative z-10\">\n                <h2 class=\"text-3xl md:text-5xl font-serif text-white tracking-tight mb-8\">Da Complexidade à Clareza</h2>\n                \n                <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12 mt-16 items-center\">\n                    <!-- Left: Chaos/Risk -->\n                    <div class=\"flex flex-col gap-4 items-center opacity-50 grayscale transition-all duration-500 hover:grayscale-0 hover:opacity-100 group\">\n                        <div class=\"relative w-64 h-64\">\n                            <!-- Papers/Documents Scattered -->\n                            <div class=\"absolute top-4 left-10 p-4 bg-white/5 border border-white/10 rounded shadow-lg transform -rotate-12 group-hover:-translate-y-2 transition-transform\">\n                                <i data-lucide=\"file-warning\" class=\"w-8 h-8 text-red-400\"></i>\n                            </div>\n                            <div class=\"absolute bottom-10 right-4 p-4 bg-white/5 border border-white/10 rounded shadow-lg transform rotate-6 group-hover:translate-y-2 transition-transform\">\n                                <i data-lucide=\"scale\" class=\"w-8 h-8 text-white/40\"></i>\n                            </div>\n                            <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-32 h-32 border border-dashed border-white/20 rounded-full flex items-center justify-center\">\n                                <span class=\"text-xs text-white/20\">LITÍGIO</span>\n                            </div>\n                        </div>\n                        <p class=\"text-xs font-medium text-white/40 uppercase tracking-widest\">Risco Jurídico</p>\n                    </div>\n\n                    <!-- Right: Order/Protection -->\n                    <div class=\"flex flex-col gap-4 items-center\">\n                        <div class=\"relative w-64 h-64 flex items-center justify-center\">\n                            <!-- Shield Rings -->\n                            <div class=\"absolute inset-0 border border-brand-gold/20 rounded-full animate-[spin_10s_linear_infinite]\"></div>\n                            <div class=\"absolute inset-4 border border-brand-gold/10 rounded-full animate-[spin_15s_linear_infinite_reverse]\"></div>\n                            \n                            <!-- Core Shield -->\n                            <div class=\"w-24 h-24 bg-brand-panel rounded-full border border-brand-gold/30 flex items-center justify-center shadow-[0_0_30px_rgba(196,164,112,0.2)] relative z-10\">\n                                <i data-lucide=\"shield-check\" class=\"w-10 h-10 text-brand-gold\"></i>\n                            </div>\n                            \n                            <!-- Particles -->\n                            <div class=\"absolute top-0 left-1/2 w-1 h-1 bg-brand-gold rounded-full shadow-[0_0_10px_#C4A470]\"></div>\n                        </div>\n                        <p class=\"text-xs font-medium text-brand-gold uppercase tracking-widest\">Segurança Jurídica</p>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- Contact Section -->\n        <section id=\"contato\" class=\"container mx-auto px-6 max-w-4xl text-center mb-24 mt-24\">\n            <div class=\"glass-panel p-8 md:p-16 rounded-[2rem] border border-white/10 relative overflow-hidden reveal\">\n                <!-- Background Gradient -->\n                <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-gradient-to-b from-brand-gold/5 to-transparent pointer-events-none\"></div>\n                \n                <h2 class=\"text-3xl md:text-5xl font-serif text-white tracking-tight mb-6 relative z-10\">Inicie uma conversa.</h2>\n                <p class=\"text-base md:text-lg text-white/50 font-light mb-12 max-w-lg mx-auto relative z-10\">\n                    O sigilo é absoluto desde o primeiro contato.\n                </p>\n\n                <form class=\"space-y-4 max-w-md mx-auto relative z-10 text-left\">\n                    <div class=\"grid grid-cols-2 gap-4\">\n                        <div class=\"space-y-1\">\n                            <label class=\"text-[10px] uppercase tracking-wider text-white/40 ml-1\">Nome</label>\n                            <input type=\"text\" class=\"w-full rounded-lg px-4 py-3 text-sm text-white tech-input placeholder-white/20\" placeholder=\"Seu nome\">\n                        </div>\n                        <div class=\"space-y-1\">\n                            <label class=\"text-[10px] uppercase tracking-wider text-white/40 ml-1\">Email</label>\n                            <input type=\"email\" class=\"w-full rounded-lg px-4 py-3 text-sm text-white tech-input placeholder-white/20\" placeholder=\"corp@email.com\">\n                        </div>\n                    </div>\n                    <div class=\"space-y-1\">\n                        <label class=\"text-[10px] uppercase tracking-wider text-white/40 ml-1\">Assunto</label>\n                        <input type=\"text\" class=\"w-full rounded-lg px-4 py-3 text-sm text-white tech-input placeholder-white/20\" placeholder=\"Natureza do caso\">\n                    </div>\n                    <div class=\"space-y-1\">\n                        <label class=\"text-[10px] uppercase tracking-wider text-white/40 ml-1\">Relato (Criptografado)</label>\n                        <textarea rows=\"3\" class=\"w-full rounded-lg px-4 py-3 text-sm text-white tech-input placeholder-white/20 resize-none\" placeholder=\"Breve descrição...\"></textarea>\n                    </div>\n                    \n                    <button type=\"button\" class=\"w-full bg-brand-gold text-brand-dark px-8 py-4 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-white transition-all duration-300 shadow-[0_0_20px_rgba(196,164,112,0.3)] mt-4\">\n                        Agendar Reunião\n                    </button>\n                    \n                    <div class=\"flex items-center justify-center gap-2 mt-6\">\n                        <i data-lucide=\"lock\" class=\"w-3 h-3 text-white/30\"></i>\n                        <span class=\"text-[10px] text-white/30\">Comunicação Protegida</span>\n                    </div>\n                </form>\n            </div>\n        </section>\n\n    </main>\n\n    <!-- Footer -->\n    <footer class=\"border-t border-white/5 bg-[#020402] pt-20 pb-10\">\n        <div class=\"container mx-auto px-6 max-w-6xl\">\n            <div class=\"flex flex-col md:flex-row justify-between gap-12 mb-16\">\n                <div>\n                    <div class=\"flex items-center gap-2 mb-6\">\n                        <div class=\"w-3 h-3 bg-brand-gold rounded-sm rotate-45\"></div>\n                        <span class=\"text-sm font-serif tracking-wide text-white\">ADEKVAT</span>\n                    </div>\n                    <p class=\"text-white/40 text-sm max-w-xs font-light\">\n                        Av. Paulista, 1000 - Cj. 1501<br>\n                        Bela Vista, São Paulo - SP\n                    </p>\n                    <div class=\"mt-6 flex flex-col gap-2\">\n                         <a href=\"tel:+551130000000\" class=\"text-xs text-white/60 hover:text-brand-gold transition-colors\">+55 11 3000-0000</a>\n                         <a href=\"mailto:contato@adekvat.com.br\" class=\"text-xs text-white/60 hover:text-brand-gold transition-colors\">contato@adekvat.com.br</a>\n                    </div>\n                </div>\n                \n                <div class=\"grid grid-cols-2 gap-12 md:gap-24\">\n                    <div class=\"flex flex-col gap-4\">\n                        <h4 class=\"text-white font-medium text-xs uppercase tracking-widest text-brand-gold\">Áreas</h4>\n                        <a href=\"#\" class=\"text-white/40 text-sm hover:text-white transition-colors\">Contencioso Cível</a>\n                        <a href=\"#\" class=\"text-white/40 text-sm hover:text-white transition-colors\">Direito Empresarial</a>\n                        <a href=\"#\" class=\"text-white/40 text-sm hover:text-white transition-colors\">Sucessão Patrimonial</a>\n                    </div>\n                    <div class=\"flex flex-col gap-4\">\n                        <h4 class=\"text-white font-medium text-xs uppercase tracking-widest text-brand-gold\">Institucional</h4>\n                        <a href=\"#\" class=\"text-white/40 text-sm hover:text-white transition-colors\">Sobre Nós</a>\n                        <a href=\"#\" class=\"text-white/40 text-sm hover:text-white transition-colors\">Equipe</a>\n                        <a href=\"#\" class=\"text-white/40 text-sm hover:text-white transition-colors\">Política de Privacidade</a>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"flex flex-col sm:flex-row justify-between items-center pt-8 border-t border-white/5 gap-4 sm:gap-0\">\n                <span class=\"text-white/20 text-xs font-mono\">© 2025 Adekvat Jurídica. OAB/SP 00.000.</span>\n                <div class=\"flex gap-4\">\n                    <i data-lucide=\"linkedin\" class=\"w-4 h-4 text-white/30 hover:text-white cursor-pointer transition-colors\"></i>\n                    <i data-lucide=\"instagram\" class=\"w-4 h-4 text-white/30 hover:text-white cursor-pointer transition-colors\"></i>\n                </div>\n            </div>\n        </div>\n    </footer>\n\n    <script>\n        // Init Icons\n        lucide.createIcons();\n\n        // Scroll Reveal Observer\n        const observer = new IntersectionObserver((entries) => {\n            entries.forEach(entry => {\n                if (entry.isIntersecting) {\n                    entry.target.classList.add('active');\n                }\n            });\n        }, { threshold: 0.1 });\n        \n        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));\n    </script>\n</body>\n</html>","language":"html","username":"043af59c-715b-4e93-aa0a-e14d3ec4c6eb","created_at":"2025-12-31T14:07:53.4465+00:00","views":236,"image_url":"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/preview-images/shared-code-previews/luxury-law-firm-11-preview-1767615464135.jpeg","forks":7,"private":false,"watermark":true,"featured":true,"share_source_code":true,"user_id":"043af59c-715b-4e93-aa0a-e14d3ec4c6eb","category":"Web","updated_at":null,"tags":["Landing Page","Services","Brand","Clean","Dark","Gradient","Large Type","Minimal","Legal","Law Firm"],"description":"Premium dark-style law firm landing page template for high-end advocacy offices to showcase practice areas, authority, and secure client consultations.","premium":false,"price":null,"purchase_url":null,"long_description":"**Luxury Law Firm Landing Page Template**\n\n## Overview\nThis template is crafted for high-end advocacy and boutique law firms seeking a dark, luxurious digital presence that inspires trust and authority.\n\n## Key Features\n- **Hero section** with bold serif typography, location and founding year badge\n- **Authority stats strip** highlighting patrimônio preservado, anos de atuação and certificações\n- **Bento-style services grid** for Contencioso Cível, Direito Empresarial and Sucessão Patrimonial\n- **Interactive legal metaphors** visualizing risco jurídico vs. segurança jurídica\n- **Secure contact form** with “Relato (Criptografado)” and strong primary CTA “Agendar Reunião”\n\n## Use Case\nIdeal for Brazilian or Portuguese-speaking law firms that handle high-complexity cases and need a sophisticated one-page site to present expertise, build credibility and convert visitors into confidential consultations.","custom_domain":null,"favicon_light_url":null,"favicon_dark_url":null,"dns_verified":null,"dns_verified_at":null,"dns_a_record":null,"netlify_apex_exists":null,"netlify_www_exists":null,"netlify_verified_at":null,"custom_domain_added_at":null,"netlify_site_id":null,"umami_website_id":null,"umami_share_id":null,"analytics_enabled":false,"gtm_container_id":null,"remix_source":{},"credit_remix_source":false}]
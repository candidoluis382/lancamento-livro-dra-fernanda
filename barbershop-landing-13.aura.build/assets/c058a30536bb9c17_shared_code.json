[{"id":15802,"slug":"barbershop-landing-13","title":"Barbershop Landing Page Template","code":"<html lang=\"en\" class=\"scroll-smooth\"><head>\n<script>\ntry{if(window.parent&&window.parent!==window){window.parent.promotekit_referral=\"1fd2949a-d22c-431b-92bf-02d4ad04ee24\";window.parent.document.cookie=\"promotekit_referral=1fd2949a-d22c-431b-92bf-02d4ad04ee24;path=/;domain=.aura.build;max-age=31536000\"}}catch(e){}\n</script>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Empire Barbershop | Precision Cuts in Tallaght</title>\n<meta name=\"description\" content=\"Premium barber shop in Tallaght, Dublin. Precision cuts, hot towel shaves, and timeless style. Book your appointment today.\">\n<!-- Fonts: Inter -->\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&amp;display=swap\" rel=\"stylesheet\">\n<!-- Tailwind CSS -->\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<!-- Iconify -->\n<script src=\"https://cdn.jsdelivr.net/npm/iconify-icon@1.0.7/dist/iconify-icon.min.js\"></script>\n<!-- Custom Config -->\n<script>\ntailwind.config = {\ntheme: {\nextend: {\nfontFamily: {\nsans: ['Inter', 'sans-serif'],\n},\ncolors: {\nneutral: {\n925: '#0f0f0f', // Custom dark\n950: '#0a0a0a',\n}\n},\nletterSpacing: {\ntighter: '-0.04em',\ntight: '-0.02em',\n}\n}\n}\n}\n</script>\n<style>\n/* Custom scrollbar for premium feel */\n::-webkit-scrollbar {\nwidth: 8px;\n}\n::-webkit-scrollbar-track {\nbackground: #0a0a0a;\n}\n::-webkit-scrollbar-thumb {\nbackground: #333;\nborder-radius: 4px;\n}\n::-webkit-scrollbar-thumb:hover {\nbackground: #555;\n}\n/* Hide details marker */\ndetails > summary {\nlist-style: none;\n}\ndetails > summary::-webkit-details-marker {\ndisplay: none;\n}\n/* Iframe container tweaks */\n.spline-bg iframe {\nborder: none;\nwidth: 100%;\nheight: 100%;\n}\n</style>\n<link id=\"all-fonts-link-font-geist\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&amp;display=swap\"><style id=\"all-fonts-style-font-geist\">.font-geist { font-family: 'Geist', sans-serif !important; }</style><link id=\"all-fonts-link-font-roboto\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;600;700&amp;display=swap\"><style id=\"all-fonts-style-font-roboto\">.font-roboto { font-family: 'Roboto', sans-serif !important; }</style><link id=\"all-fonts-link-font-montserrat\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&amp;display=swap\"><style id=\"all-fonts-style-font-montserrat\">.font-montserrat { font-family: 'Montserrat', sans-serif !important; }</style><link id=\"all-fonts-link-font-poppins\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&amp;display=swap\"><style id=\"all-fonts-style-font-poppins\">.font-poppins { font-family: 'Poppins', sans-serif !important; }</style><link id=\"all-fonts-link-font-playfair\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;900&amp;display=swap\"><style id=\"all-fonts-style-font-playfair\">.font-playfair { font-family: 'Playfair Display', serif !important; }</style><link id=\"all-fonts-link-font-instrument-serif\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Instrument+Serif:wght@400;500;600;700&amp;display=swap\"><style id=\"all-fonts-style-font-instrument-serif\">.font-instrument-serif { font-family: 'Instrument Serif', serif !important; }</style><link id=\"all-fonts-link-font-merriweather\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700;900&amp;display=swap\"><style id=\"all-fonts-style-font-merriweather\">.font-merriweather { font-family: 'Merriweather', serif !important; }</style><link id=\"all-fonts-link-font-bricolage\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@300;400;500;600;700&amp;display=swap\"><style id=\"all-fonts-style-font-bricolage\">.font-bricolage { font-family: 'Bricolage Grotesque', sans-serif !important; }</style><link id=\"all-fonts-link-font-jakarta\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;display=swap\"><style id=\"all-fonts-style-font-jakarta\">.font-jakarta { font-family: 'Plus Jakarta Sans', sans-serif !important; }</style><link id=\"all-fonts-link-font-manrope\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&amp;display=swap\"><style id=\"all-fonts-style-font-manrope\">.font-manrope { font-family: 'Manrope', sans-serif !important; }</style><link id=\"all-fonts-link-font-space-grotesk\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;display=swap\"><style id=\"all-fonts-style-font-space-grotesk\">.font-space-grotesk { font-family: 'Space Grotesk', sans-serif !important; }</style><link id=\"all-fonts-link-font-work-sans\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Work+Sans:wght@300;400;500;600;700;800&amp;display=swap\"><style id=\"all-fonts-style-font-work-sans\">.font-work-sans { font-family: 'Work Sans', sans-serif !important; }</style><link id=\"all-fonts-link-font-pt-serif\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=PT+Serif:wght@400;700&amp;display=swap\"><style id=\"all-fonts-style-font-pt-serif\">.font-pt-serif { font-family: 'PT Serif', serif !important; }</style><link id=\"all-fonts-link-font-geist-mono\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Geist+Mono:wght@300;400;500;600;700&amp;display=swap\"><style id=\"all-fonts-style-font-geist-mono\">.font-geist-mono { font-family: 'Geist Mono', monospace !important; }</style><link id=\"all-fonts-link-font-space-mono\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&amp;display=swap\"><style id=\"all-fonts-style-font-space-mono\">.font-space-mono { font-family: 'Space Mono', monospace !important; }</style><link id=\"all-fonts-link-font-quicksand\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&amp;display=swap\"><style id=\"all-fonts-style-font-quicksand\">.font-quicksand { font-family: 'Quicksand', sans-serif !important; }</style><link id=\"all-fonts-link-font-nunito\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;500;600;700;800&amp;display=swap\"><style id=\"all-fonts-style-font-nunito\">.font-nunito { font-family: 'Nunito', sans-serif !important; }</style><link id=\"all-fonts-link-font-newsreader\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Newsreader:opsz,wght@6..72,400..800&amp;display=swap\"><style id=\"all-fonts-style-font-newsreader\">.font-newsreader { font-family: 'Newsreader', serif !important; }</style><link id=\"all-fonts-link-font-google-sans-flex\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Google+Sans+Flex:wght@400;500;600;700&amp;display=swap\"><style id=\"all-fonts-style-font-google-sans-flex\">.font-google-sans-flex { font-family: 'Google Sans Flex', sans-serif !important; }</style><link id=\"all-fonts-link-font-oswald\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&amp;display=swap\"><style id=\"all-fonts-style-font-oswald\">.font-oswald { font-family: 'Oswald', sans-serif !important; }</style><link id=\"all-fonts-link-font-dm-sans\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&amp;display=swap\"><style id=\"all-fonts-style-font-dm-sans\">.font-dm-sans { font-family: 'DM Sans', sans-serif !important; }</style><link id=\"all-fonts-link-font-cormorant\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&amp;display=swap\"><style id=\"all-fonts-style-font-cormorant\">.font-cormorant { font-family: 'Cormorant Garamond', serif !important; }</style></head>\n<body class=\"bg-neutral-950 text-neutral-300 font-sans antialiased selection:bg-white/20 selection:text-white\">\n\n    <!-- Navigation -->\n    <nav class=\"fixed w-full z-50 top-0 start-0 border-b border-white/5 bg-neutral-950/50 backdrop-blur-md transition-all duration-300\">\n        <div class=\"max-w-7xl mx-auto flex flex-wrap items-center justify-between px-6 py-4\">\n            <a href=\"#\" class=\"flex items-center space-x-2 rtl:space-x-reverse group\">\n                <span class=\"self-center text-xl font-semibold whitespace-nowrap text-white tracking-tighter group-hover:text-neutral-300 transition-colors\">EMPIRE</span>\n            </a>\n            \n            <!-- Mobile Menu Button -->\n            <button onclick=\"document.getElementById('mobile-menu').classList.toggle('hidden')\" type=\"button\" class=\"inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-neutral-400 rounded-lg md:hidden hover:bg-neutral-900 focus:outline-none focus:ring-2 focus:ring-neutral-600\">\n                <span class=\"sr-only\">Open main menu</span>\n                <iconify-icon icon=\"lucide:menu\" width=\"24\" height=\"24\" stroke-width=\"1.5\"></iconify-icon>\n            </button>\n\n            <!-- Desktop Menu -->\n            <div class=\"hidden w-full md:block md:w-auto\">\n                <ul class=\"font-medium flex flex-col p-4 md:p-0 mt-4 border border-neutral-800 rounded-lg bg-neutral-900 md:flex-row md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0 md:bg-transparent\">\n                    <li><a href=\"#home\" class=\"block py-2 px-3 text-white rounded md:bg-transparent md:p-0 hover:text-neutral-400 transition-colors text-sm\">Home</a></li>\n                    <li><a href=\"#about\" class=\"block py-2 px-3 text-neutral-400 rounded hover:bg-neutral-800 md:hover:bg-transparent md:border-0 md:hover:text-white md:p-0 transition-colors text-sm\">About</a></li>\n                    <li class=\"\"><a href=\"#services\" class=\"block py-2 px-3 text-neutral-400 rounded hover:bg-neutral-800 md:hover:bg-transparent md:border-0 md:hover:text-white md:p-0 transition-colors text-sm\">Services</a></li>\n                    <li class=\"\"><a href=\"#blog\" class=\"block py-2 px-3 text-neutral-400 rounded hover:bg-neutral-800 md:hover:bg-transparent md:border-0 md:hover:text-white md:p-0 transition-colors text-sm\">Journal</a></li>\n                    <li><a href=\"#contact\" class=\"block py-2 px-3 text-neutral-400 rounded hover:bg-neutral-800 md:hover:bg-transparent md:border-0 md:hover:text-white md:p-0 transition-colors text-sm\">Contact</a></li>\n                </ul>\n            </div>\n            \n            <div class=\"hidden md:block\">\n                <a href=\"#book\" class=\"text-white bg-white/10 backdrop-blur-sm border border-white/10 hover:bg-white hover:text-neutral-950 font-medium rounded text-sm px-5 py-2.5 focus:outline-none transition-all duration-300 tracking-tight\">Book Appointment</a>\n            </div>\n        </div>\n\n        <!-- Mobile Menu Dropdown -->\n        <div id=\"mobile-menu\" class=\"hidden md:hidden w-full bg-neutral-900 border-b border-neutral-800\">\n             <ul class=\"flex flex-col p-4 font-medium\">\n                <li><a href=\"#home\" class=\"block py-3 px-3 text-white border-b border-neutral-800\">Home</a></li>\n                <li><a href=\"#about\" class=\"block py-3 px-3 text-neutral-400 border-b border-neutral-800\">About</a></li>\n                <li><a href=\"#services\" class=\"block py-3 px-3 text-neutral-400 border-b border-neutral-800\">Services</a></li>\n                <li><a href=\"#blog\" class=\"block py-3 px-3 text-neutral-400 border-b border-neutral-800\">Journal</a></li>\n                <li><a href=\"#contact\" class=\"block py-3 px-3 text-neutral-400 mb-4\">Contact</a></li>\n                \n            </ul>\n        </div>\n    </nav>\n\n    <!-- Hero Section with Spline 3D -->\n    <section id=\"home\" class=\"relative w-full h-screen min-h-[800px] flex items-center justify-center overflow-hidden bg-neutral-950\">\n        \n        <!-- Spline Background Container -->\n        <div class=\"spline-bg absolute inset-0 w-full h-full z-0\">\n             <!-- Updated Iframe Source -->\n             <iframe src=\"https://my.spline.design/retrofuturismbganimation-OOfTQTYrMn6YWLRk15W2SLmM/\" frameborder=\"0\" width=\"100%\" height=\"100%\"></iframe>\n        </div>\n\n        <!-- Gradient Overlays for Readability & Transition -->\n        <div class=\"absolute inset-0 z-0 bg-gradient-to-b from-neutral-950/80 via-transparent to-neutral-950 pointer-events-none\"></div>\n        <div class=\"absolute inset-0 z-0 bg-neutral-950/20 pointer-events-none\"></div>\n\n        <!-- Content -->\n        <div class=\"relative z-10 max-w-7xl mx-auto px-6 text-center mt-16 pointer-events-none\">\n            <h1 class=\"text-5xl md:text-7xl lg:text-8xl font-semibold text-white tracking-tighter mb-6 leading-[1.1] drop-shadow-2xl\">\n                Precision Cuts.\n                <span class=\"text-neutral-400\">Timeless Style.</span>\n            </h1>\n            <p class=\"mt-6 text-lg md:text-xl text-neutral-300 max-w-2xl mx-auto leading-relaxed font-light drop-shadow-lg\">\n                Experience the art of grooming at Empire Barbershop. We combine traditional craftsmanship with modern aesthetics for the man who values detail.\n            </p>\n            <div class=\"mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center pointer-events-auto\">\n                <a href=\"#book\" class=\"group relative inline-flex h-12 items-center justify-center overflow-hidden rounded bg-white px-8 font-medium text-neutral-950 transition-all duration-300 hover:bg-neutral-200 hover:scale-[1.02]\">\n                    <span class=\"mr-2\">Book an Appointment</span>\n                    <iconify-icon icon=\"lucide:arrow-right\" width=\"18\" height=\"18\" class=\"transition-transform group-hover:translate-x-1\" stroke-width=\"1.5\"></iconify-icon>\n                </a>\n                <a href=\"#services\" class=\"inline-flex h-12 items-center justify-center rounded border border-white/20 bg-black/20 backdrop-blur-sm px-8 font-medium text-white transition-colors hover:bg-white/10\">\n                    View Services\n                </a>\n            </div>\n        </div>\n    </section>\n\n    <!-- Visual Section -->\n    <section class=\"md:px-6 w-full max-w-[1400px] mr-auto mb-24 ml-auto pr-4 pl-4 -mt-12 relative z-20\">\n        <div class=\"relative aspect-[16/9] md:aspect-[21/9] overflow-hidden rounded-xl bg-neutral-900 group border border-white/10 shadow-2xl\">\n            <img src=\"https://images.unsplash.com/photo-1585747860715-2ba37e788b70?w=3840&amp;q=80\" alt=\"Barber cutting hair\" class=\"group-hover:scale-105 transition-transform duration-700 ease-out opacity-80 w-full h-full object-cover\">\n            <div class=\"bg-gradient-to-t from-neutral-950 via-transparent to-transparent opacity-90 absolute top-0 right-0 bottom-0 left-0\"></div>\n            <div class=\"absolute bottom-6 left-6 md:bottom-12 md:left-12 max-w-lg\">\n                <p class=\"text-xs font-medium uppercase tracking-widest text-white/60 mb-2\">Atmosphere</p>\n                <h3 class=\"md:text-3xl text-2xl font-semibold text-white tracking-tight\">Where craftsmanship meets comfort.</h3>\n            </div>\n        </div>\n    </section>\n\n    <!-- Trust / Featured In -->\n    <section class=\"border-y border-white/5 bg-neutral-925 py-12\">\n        <div class=\"max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-8\">\n            <div class=\"flex items-center gap-4\">\n                <div class=\"flex items-center text-amber-400 gap-1\">\n                    <iconify-icon icon=\"lucide:star\" width=\"20\" height=\"20\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"20\" height=\"20\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"20\" height=\"20\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"20\" height=\"20\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star-half\" width=\"20\" height=\"20\" class=\"fill-current\"></iconify-icon>\n                </div>\n                <div class=\"flex flex-col\">\n                    <span class=\"text-white font-medium leading-none\">4.6 / 5 Rating</span>\n                    <span class=\"text-sm text-neutral-500 mt-1\">Based on 62 reviews</span>\n                </div>\n            </div>\n            <div class=\"h-px w-full md:w-px md:h-12 bg-white/10\"></div>\n            <div class=\"text-center md:text-left\">\n                <p class=\"text-neutral-400 text-sm font-medium uppercase tracking-widest mb-3 md:mb-0\">Trusted by the Tallaght Community</p>\n            </div>\n            <div class=\"flex items-center gap-8 opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-500\">\n                <span class=\"text-lg font-bold tracking-tight text-white\">BARBER<span class=\"font-light\">LIFE</span></span>\n                <span class=\"text-lg font-bold tracking-tight text-white\">DUBLIN<span class=\"font-light\">CUTS</span></span>\n                <span class=\"text-lg font-bold tracking-tight text-white\">MEN'S<span class=\"font-light\">STYLE</span></span>\n            </div>\n        </div>\n    </section>\n\n    <!-- Mission / About Preview -->\n    <section id=\"about\" class=\"py-24 max-w-7xl mx-auto px-6\">\n        <div class=\"grid md:grid-cols-2 gap-16 items-center\">\n            <div class=\"\">\n                <h2 class=\"text-3xl md:text-4xl font-semibold text-white tracking-tight mb-6\">More than just a haircut.</h2>\n                <div class=\"space-y-4 text-neutral-400 leading-relaxed\">\n                    <p class=\"\">\n                        At Empire Barbershop, we believe that a haircut is the foundation of a man's confidence. Located in the heart of Tallaght, we have built a reputation for excellence, consistency, and a welcoming atmosphere.\n                    </p>\n                    <p class=\"\">\n                        Our barbers are masters of their craft, blending traditional techniques with modern styling. Whether you're here for a skin fade or a hot towel shave, our attention to detail is unwavering.\n                    </p>\n                </div>\n                <div class=\"mt-8 grid grid-cols-2 gap-6\">\n                    <div>\n                        <h4 class=\"text-white font-medium mb-1\">Expert Team</h4>\n                        <p class=\"text-sm text-neutral-500\">Qualified professionals with years of experience.</p>\n                    </div>\n                    <div class=\"\">\n                        <h4 class=\"text-white font-medium mb-1\">Local Focus</h4>\n                        <p class=\"text-sm text-neutral-500\">Proudly serving Tallaght and Dublin D24.</p>\n                    </div>\n                </div>\n            </div>\n            <div class=\"relative\">\n                <div class=\"aspect-square rounded-lg overflow-hidden bg-neutral-900 border border-white/5\">\n                    <img src=\"https://images.unsplash.com/photo-1590540179852-2110a54f813a?w=1600&amp;q=80\" alt=\"Barber Tools\" class=\"hover:scale-105 transition-transform duration-700 w-full h-full object-cover\">\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Services -->\n    <section id=\"services\" class=\"py-24 bg-neutral-925 border-y border-white/5\">\n        <div class=\"max-w-7xl mx-auto px-6\">\n            <div class=\"text-center max-w-2xl mx-auto mb-16\">\n                <h2 class=\"text-3xl md:text-4xl font-semibold text-white tracking-tight mb-4\">Our Services</h2>\n                <p class=\"text-neutral-400\">Tailored grooming services designed to help you look your best.</p>\n            </div>\n\n            <div class=\"grid md:grid-cols-3 gap-6\">\n                <!-- Service 1 -->\n                <div class=\"group p-8 rounded-xl bg-neutral-950 border border-white/5 hover:border-white/10 transition-colors\">\n                    <div class=\"w-12 h-12 rounded-full bg-neutral-900 flex items-center justify-center mb-6 text-white group-hover:bg-white group-hover:text-black transition-colors\">\n                        <iconify-icon icon=\"lucide:scissors\" width=\"24\" height=\"24\" stroke-width=\"1.5\"></iconify-icon>\n                    </div>\n                    <h3 class=\"text-xl font-semibold text-white mb-3\">Precision Haircut</h3>\n                    <p class=\"text-neutral-400 text-sm leading-relaxed mb-4\">A tailored cut to suit your face shape and style preference. Finished with styling product.</p>\n                    <span class=\"text-sm font-medium text-white\">From €20</span>\n                </div>\n\n                <!-- Service 2 -->\n                <div class=\"group p-8 rounded-xl bg-neutral-950 border border-white/5 hover:border-white/10 transition-colors\">\n                    <div class=\"w-12 h-12 rounded-full bg-neutral-900 flex items-center justify-center mb-6 text-white group-hover:bg-white group-hover:text-black transition-colors\">\n                        <iconify-icon icon=\"lucide:zap\" width=\"24\" height=\"24\" stroke-width=\"1.5\"></iconify-icon>\n                    </div>\n                    <h3 class=\"text-xl font-semibold text-white mb-3\">Skin Fade</h3>\n                    <p class=\"text-neutral-400 text-sm leading-relaxed mb-4\">Seamless gradient fade using foils for a smooth, sharp finish. The modern standard.</p>\n                    <span class=\"text-sm font-medium text-white\">From €25</span>\n                </div>\n\n                <!-- Service 3 -->\n                <div class=\"group p-8 rounded-xl bg-neutral-950 border border-white/5 hover:border-white/10 transition-colors\">\n                    <div class=\"w-12 h-12 rounded-full bg-neutral-900 flex items-center justify-center mb-6 text-white group-hover:bg-white group-hover:text-black transition-colors\">\n                        <iconify-icon icon=\"lucide:shield\" width=\"24\" height=\"24\" stroke-width=\"1.5\"></iconify-icon>\n                    </div>\n                    <h3 class=\"text-xl font-semibold text-white mb-3\">Beard Sculpting</h3>\n                    <p class=\"text-neutral-400 text-sm leading-relaxed mb-4\">Shape, trim, and line up your beard. Includes beard oil application for health.</p>\n                    <span class=\"text-sm font-medium text-white\">From €15</span>\n                </div>\n\n                 <!-- Service 4 -->\n                 <div class=\"group p-8 rounded-xl bg-neutral-950 border border-white/5 hover:border-white/10 transition-colors\">\n                    <div class=\"w-12 h-12 rounded-full bg-neutral-900 flex items-center justify-center mb-6 text-white group-hover:bg-white group-hover:text-black transition-colors\">\n                        <iconify-icon icon=\"lucide:thermometer\" width=\"24\" height=\"24\" stroke-width=\"1.5\"></iconify-icon>\n                    </div>\n                    <h3 class=\"text-xl font-semibold text-white mb-3\">Hot Towel Shave</h3>\n                    <p class=\"text-neutral-400 text-sm leading-relaxed mb-4\">Traditional straight razor shave with hot towels and premium shaving cream.</p>\n                    <span class=\"text-sm font-medium text-white\">From €30</span>\n                </div>\n\n                <!-- Service 5 -->\n                <div class=\"group p-8 rounded-xl bg-neutral-950 border border-white/5 hover:border-white/10 transition-colors md:col-span-2\">\n                    <div class=\"w-12 h-12 rounded-full bg-neutral-900 flex items-center justify-center mb-6 text-white group-hover:bg-white group-hover:text-black transition-colors\">\n                        <iconify-icon icon=\"lucide:crown\" width=\"24\" height=\"24\" stroke-width=\"1.5\"></iconify-icon>\n                    </div>\n                    <h3 class=\"text-xl font-semibold text-white mb-3\">The Empire Package</h3>\n                    <p class=\"text-neutral-400 text-sm leading-relaxed mb-4\">The full experience. Precision haircut, hot towel shave, ear/nose waxing, and a drink of choice. Walk out a new man.</p>\n                    <span class=\"text-sm font-medium text-white\">From €50</span>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Pricing Section -->\n    <section class=\"py-24 max-w-4xl mx-auto px-6\">\n        <div class=\"text-center mb-12\">\n            <h2 class=\"text-3xl md:text-4xl font-semibold text-white tracking-tight\">Price List</h2>\n        </div>\n        \n        <div class=\"space-y-4\">\n            <!-- Price Item -->\n            <div class=\"flex items-end justify-between border-b border-neutral-800 pb-4\">\n                <div>\n                    <h4 class=\"text-lg font-medium text-white\">Dry Cut</h4>\n                    <p class=\"text-xs text-neutral-500 mt-1\">Standard cut, no wash</p>\n                </div>\n                <span class=\"text-lg font-semibold text-white\">€20</span>\n            </div>\n             <!-- Price Item -->\n             <div class=\"flex items-end justify-between border-b border-neutral-800 pb-4\">\n                <div>\n                    <h4 class=\"text-lg font-medium text-white\">Wash, Cut &amp; Style</h4>\n                    <p class=\"text-xs text-neutral-500 mt-1\">Includes consultation</p>\n                </div>\n                <span class=\"text-lg font-semibold text-white\">€25</span>\n            </div>\n             <!-- Price Item -->\n             <div class=\"flex items-end justify-between border-b border-neutral-800 pb-4\">\n                <div>\n                    <div class=\"flex items-center gap-2\">\n                        <h4 class=\"text-lg font-medium text-white\">Skin Fade</h4>\n                        <span class=\"px-2 py-0.5 rounded-full bg-neutral-800 text-[10px] text-white uppercase tracking-wider font-semibold\">Popular</span>\n                    </div>\n                    <p class=\"text-xs text-neutral-500 mt-1\">Zero or foil finish</p>\n                </div>\n                <span class=\"text-lg font-semibold text-white\">€25</span>\n            </div>\n             <!-- Price Item -->\n             <div class=\"flex items-end justify-between border-b border-neutral-800 pb-4\">\n                <div>\n                    <h4 class=\"text-lg font-medium text-white\">Beard Trim &amp; Line Up</h4>\n                    <p class=\"text-xs text-neutral-500 mt-1\">Razor finish</p>\n                </div>\n                <span class=\"text-lg font-semibold text-white\">€15</span>\n            </div>\n             <!-- Price Item -->\n             <div class=\"flex items-end justify-between border-b border-neutral-800 pb-4\">\n                <div>\n                    <h4 class=\"text-lg font-medium text-white\">Father &amp; Son</h4>\n                    <p class=\"text-xs text-neutral-500 mt-1\">Under 12s</p>\n                </div>\n                <span class=\"text-lg font-semibold text-white\">€35</span>\n            </div>\n        </div>\n        <div class=\"mt-8 text-center\">\n            <a href=\"#book\" class=\"text-sm text-neutral-400 hover:text-white underline decoration-neutral-700 underline-offset-4\">View full price list on booking page</a>\n        </div>\n    </section>\n\n    <!-- How It Works -->\n    <section class=\"py-24 bg-neutral-925 border-y border-white/5\">\n        <div class=\"max-w-7xl mx-auto px-6\">\n            <div class=\"grid md:grid-cols-3 gap-12 relative\">\n                <!-- Line connector for desktop -->\n                <div class=\"hidden md:block absolute top-8 left-[16%] right-[16%] h-px bg-gradient-to-r from-transparent via-neutral-700 to-transparent border-t border-dashed border-neutral-700\"></div>\n\n                <div class=\"text-center relative z-10\">\n                    <div class=\"w-16 h-16 mx-auto bg-neutral-950 border border-neutral-800 rounded-2xl flex items-center justify-center text-white mb-6 shadow-lg\">\n                        <iconify-icon icon=\"lucide:calendar-check\" width=\"24\" height=\"24\" stroke-width=\"1.5\"></iconify-icon>\n                    </div>\n                    <h3 class=\"text-lg font-semibold text-white mb-2\">1. Book Appointment</h3>\n                    <p class=\"text-sm text-neutral-500 px-4\">Select your service and preferred time online in seconds.</p>\n                </div>\n\n                <div class=\"text-center relative z-10\">\n                    <div class=\"w-16 h-16 mx-auto bg-neutral-950 border border-neutral-800 rounded-2xl flex items-center justify-center text-white mb-6 shadow-lg\">\n                        <iconify-icon icon=\"lucide:user\" width=\"24\" height=\"24\" stroke-width=\"1.5\"></iconify-icon>\n                    </div>\n                    <h3 class=\"text-lg font-semibold text-white mb-2\">2. Choose Your Style</h3>\n                    <p class=\"text-sm text-neutral-500 px-4\">Consult with our barbers to find the look that suits you.</p>\n                </div>\n\n                <div class=\"text-center relative z-10\">\n                    <div class=\"w-16 h-16 mx-auto bg-neutral-950 border border-neutral-800 rounded-2xl flex items-center justify-center text-white mb-6 shadow-lg\">\n                        <iconify-icon icon=\"lucide:check-circle\" width=\"24\" height=\"24\" stroke-width=\"1.5\"></iconify-icon>\n                    </div>\n                    <h3 class=\"text-lg font-semibold text-white mb-2\">3. Walk Out Sharp</h3>\n                    <p class=\"text-sm text-neutral-500 px-4\">Leave feeling confident, refreshed, and ready.</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Testimonials -->\n    <section class=\"py-24 max-w-7xl mx-auto px-6 overflow-hidden\">\n        <h2 class=\"text-3xl md:text-4xl font-semibold text-white tracking-tight mb-12 text-center\">Client Stories</h2>\n        \n        <div class=\"grid md:grid-cols-3 gap-6\">\n            <!-- Review 1 -->\n            <div class=\"bg-neutral-900 p-8 rounded-xl relative\">\n                <iconify-icon icon=\"lucide:quote\" class=\"text-neutral-800 absolute top-6 right-6\" width=\"40\" height=\"40\"></iconify-icon>\n                <div class=\"flex text-amber-400 mb-4 gap-0.5\">\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                </div>\n                <p class=\"text-neutral-300 mb-6 text-sm leading-relaxed\">\"Best barber in Tallaght hands down. The fade is always clean and the lads are sound. Left feeling brand new.\"</p>\n                <div>\n                    <p class=\"text-white font-medium text-sm\">Conor O'Sullivan</p>\n                    <p class=\"text-neutral-500 text-xs\">Regular Client</p>\n                </div>\n            </div>\n\n             <!-- Review 2 -->\n             <div class=\"bg-neutral-900 p-8 rounded-xl relative\">\n                <iconify-icon icon=\"lucide:quote\" class=\"text-neutral-800 absolute top-6 right-6\" width=\"40\" height=\"40\"></iconify-icon>\n                <div class=\"flex text-amber-400 mb-4 gap-0.5\">\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                </div>\n                <p class=\"text-neutral-300 mb-6 text-sm leading-relaxed\">\"Great atmosphere and professional service. Booked online, no waiting around. The hot towel shave is top tier.\"</p>\n                <div>\n                    <p class=\"text-white font-medium text-sm\">Mark Byrne</p>\n                    <p class=\"text-neutral-500 text-xs\">Local Guide</p>\n                </div>\n            </div>\n\n             <!-- Review 3 -->\n             <div class=\"bg-neutral-900 p-8 rounded-xl relative\">\n                <iconify-icon icon=\"lucide:quote\" class=\"text-neutral-800 absolute top-6 right-6\" width=\"40\" height=\"40\"></iconify-icon>\n                <div class=\"flex text-amber-400 mb-4 gap-0.5\">\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                    <iconify-icon icon=\"lucide:star\" width=\"16\" height=\"16\" class=\"fill-current\"></iconify-icon>\n                </div>\n                <p class=\"text-neutral-300 mb-6 text-sm leading-relaxed\">\"Finally found a place that knows how to handle a beard properly. Attention to detail is unmatched in D24.\"</p>\n                <div>\n                    <p class=\"text-white font-medium text-sm\">David Murphy</p>\n                    <p class=\"text-neutral-500 text-xs\">First-time Customer</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Blog Section -->\n    <section id=\"blog\" class=\"py-24 bg-neutral-925 border-y border-white/5\">\n        <div class=\"max-w-7xl mx-auto px-6\">\n            <div class=\"flex justify-between items-end mb-12\">\n                <div>\n                    <h2 class=\"text-3xl md:text-4xl font-semibold text-white tracking-tight\">The Journal</h2>\n                    <p class=\"text-neutral-400 mt-2\">Insights on grooming, style, and culture.</p>\n                </div>\n                <a href=\"#\" class=\"text-sm text-white border-b border-white pb-1 hover:opacity-70 transition-opacity hidden md:block\">Read all articles</a>\n            </div>\n\n            <div class=\"grid md:grid-cols-2 lg:grid-cols-4 gap-6\">\n                <!-- Article 1 -->\n                <article class=\"group cursor-pointer\">\n                    <div class=\"aspect-[4/3] bg-neutral-800 rounded-lg overflow-hidden mb-4\">\n                        <img src=\"https://images.unsplash.com/photo-1621605815971-fbc98d665033?q=80&amp;w=1000&amp;auto=format&amp;fit=crop\" class=\"w-full h-ful
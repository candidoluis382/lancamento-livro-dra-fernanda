rif'],\ndisplay: ['Inter', 'sans-serif'],\n},\nletterSpacing: {\ntight: '-0.025em',\ntighter: '-0.04em',\n}\n}\n}\n}\n</script></head>\n<body class=\"bg-neutral-950 text-neutral-400 antialiased selection:bg-brand-500/30 selection:text-brand-50\">\n\n    <!-- Navigation -->\n    <nav class=\"fixed top-0 w-full z-50 border-b border-neutral-800 glass-panel\">\n        <div class=\"max-w-7xl mx-auto px-6 h-16 flex items-center justify-between\">\n            <div class=\"flex items-center gap-3\">\n                <div class=\"w-8 h-8 bg-neutral-100 rounded flex items-center justify-center shrink-0 text-neutral-950\">\n                    <span class=\"iconify\" data-icon=\"lucide:dumbbell\" data-width=\"18\" data-stroke-width=\"2\"></span>\n                </div>\n                <span class=\"font-display font-semibold text-neutral-100 tracking-tight text-base uppercase\">Bona Forma</span>\n            </div>\n            <div class=\"hidden lg:flex items-center gap-8 text-[14px] font-medium\">\n                <a href=\"#serveis\" class=\"hover:text-white transition-colors duration-300 ease-in-out\">Serveis</a>\n                <a href=\"#instalacions\" class=\"hover:text-white transition-colors duration-300 ease-in-out\">Instal·lacions</a>\n                <a href=\"#contacte\" class=\"hover:text-white transition-colors duration-300 ease-in-out\">Contacte</a>\n            </div>\n            <div class=\"flex items-center gap-4\">\n                <a href=\"tel:+376123456\" class=\"hidden md:flex items-center gap-2 text-[14px] text-neutral-300 hover:text-white transition-colors\">\n                    <span class=\"iconify\" data-icon=\"lucide:phone\" data-width=\"16\" data-stroke-width=\"1.5\"></span>\n                    (+376) 123 456\n                </a>\n                <button class=\"bg-neutral-100 hover:bg-neutral-200 text-neutral-950 text-[14px] font-semibold px-5 py-2 rounded-full transition-colors duration-300 ease-in-out\">\n                    Uneix-te ara\n                </button>\n            </div>\n        </div>\n    </nav>\n\n    <!-- Hero Section -->\n    <header class=\"md:pt-48 md:pb-32 overflow-hidden pt-32 pr-6 pb-20 pl-6 relative\">\n        <!-- Glow Effect -->\n        <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-brand-500/10 blur-[120px] rounded-full pointer-events-none\"></div>\n\n        <div class=\"max-w-4xl mx-auto text-center relative z-10\">\n            <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full border border-neutral-800 bg-neutral-900/50 text-[12px] font-medium text-brand-500 mb-8\">\n                <span class=\"relative flex h-2 w-2\">\n                    <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-500 opacity-75\"></span>\n                    <span class=\"relative inline-flex rounded-full h-2 w-2 bg-brand-500\"></span>\n                </span>\n                Obert 24 hores • Andorra la Vella\n            </div>\n            \n            <h1 class=\"font-display text-[40px] md:text-7xl font-semibold text-white tracking-tighter mb-6 leading-[1.1]\">\n                Entrena sense <br class=\"hidden md:block\">\n                <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-white via-neutral-200 to-neutral-500\">límits a Andorra.</span>\n            </h1>\n            \n            <p class=\"text-[16px] md:text-[18px] text-neutral-400 mb-10 max-w-2xl mx-auto leading-relaxed\">\n                El teu espai de fitness premium. Accés biomètric 24/7, maquinària d'alta gamma i entrenaments personals dissenyats per a tu.\n            </p>\n\n            <div class=\"flex flex-col items-center gap-6\">\n                <div class=\"flex flex-col md:flex-row items-center justify-center gap-4 w-full\">\n                    <button class=\"w-full md:w-auto bg-white hover:bg-neutral-200 text-neutral-950 h-12 px-8 rounded-full font-semibold text-[14px] transition-all duration-300 ease-in-out flex items-center justify-center gap-2\">\n                        Comença avui\n                        <span class=\"iconify\" data-icon=\"lucide:arrow-right\" data-width=\"16\" data-stroke-width=\"2\"></span>\n                    </button>\n                    <button class=\"w-full md:w-auto h-12 px-8 rounded-full font-medium text-[14px] text-neutral-300 border border-neutral-800 hover:bg-neutral-800/50 transition-all duration-300 ease-in-out flex items-center justify-center gap-2\">\n                        Veure tarifes\n                    </button>\n                </div>\n            </div>\n        </div>\n\n        <!-- Hero Image -->\n        <div class=\"mt-20 relative max-w-6xl mx-auto border border-neutral-800 rounded-2xl bg-neutral-900 overflow-hidden h-64 md:h-[500px] shadow-2xl\">\n            <img src=\"https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=2070&auto=format&fit=crop\" alt=\"Interior Gimnàs Bona Forma\" class=\"absolute inset-0 w-full h-full object-cover opacity-60\">\n            <div class=\"image-overlay absolute top-0 right-0 bottom-0 left-0\"></div>\n            \n            <!-- Overlay Info -->\n            <div class=\"absolute bottom-0 left-0 w-full p-8 md:p-12 flex items-end justify-between\">\n                <div class=\"hidden md:block\">\n                    <div class=\"flex items-center gap-2 mb-2\">\n                        <div class=\"h-2 w-2 rounded-full bg-brand-500 animate-pulse\"></div>\n                        <span class=\"text-[12px] uppercase tracking-widest text-neutral-300 font-medium\">Aforament actual: Baix</span>\n                    </div>\n                    <p class=\"text-neutral-400 text-[14px]\">Carrer Prat de la Creu, Andorra.</p>\n                </div>\n                <div class=\"grid grid-cols-3 gap-6 md:gap-12 w-full md:w-auto\">\n                    <div class=\"flex flex-col items-center md:items-start gap-1\">\n                        <span class=\"font-display text-[24px] md:text-[32px] font-semibold text-white tracking-tight\">24h</span>\n                        <span class=\"text-[12px] text-neutral-400 uppercase tracking-wide font-semibold\">Accés</span>\n                    </div>\n                    <div class=\"flex flex-col items-center md:items-start gap-1\">\n                        <span class=\"font-display text-[24px] md:text-[32px] font-semibold text-white tracking-tight\">365</span>\n                        <span class=\"text-[12px] text-neutral-400 uppercase tracking-wide font-semibold\">Dies</span>\n                    </div>\n                    <div class=\"flex flex-col items-center md:items-start gap-1\">\n                        <span class=\"font-display text-[24px] md:text-[32px] font-semibold text-white tracking-tight\">100%</span>\n                        <span class=\"text-[12px] text-neutral-400 uppercase tracking-wide font-semibold\">Premium</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </header>\n\n    <!-- Brands -->\n    <section class=\"border-y border-neutral-800 bg-neutral-950/50 py-10\">\n        <div class=\"max-w-7xl mx-auto px-6 text-center\">\n            <p class=\"text-[12px] text-neutral-500 mb-8 font-semibold tracking-widest uppercase\">Equipament d'alta competició</p>\n            <div class=\"flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-40 grayscale hover:grayscale-0 transition-all duration-500\">\n                <span class=\"font-display text-xl font-bold tracking-tighter text-white\">Techno<span class=\"font-light text-neutral-400\">gym</span></span>\n                <span class=\"font-display text-xl font-semibold tracking-widest text-white uppercase\">Hammer</span>\n                <span class=\"font-display text-xl font-bold italic tracking-tight text-white\">ELEIKO</span>\n                <span class=\"font-display text-xl font-light tracking-wide text-white uppercase border border-white px-2\">Rogue</span>\n                <span class=\"font-display text-xl font-medium tracking-tight text-white\">Life<span class=\"text-brand-500\">Fitness</span></span>\n            </div>\n        </div>\n    </section>\n\n    <!-- Services Grid -->\n    <section id=\"serveis\" class=\"py-24 px-6 relative bg-neutral-950\">\n        <div class=\"max-w-7xl mx-auto\">\n            <div class=\"mb-16 md:mb-20\">\n                <h2 class=\"font-display text-[32px] md:text-[40px] font-semibold text-white tracking-tight mb-4\">Tot el que necessites</h2>\n                <p class=\"text-neutral-400 text-[16px] max-w-xl leading-relaxed\">Un ecosistema complet per al teu rendiment físic. Des de la llibertat d'horaris fins al millor assessorament professional.</p>\n            </div>\n            \n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n                <!-- Service 1 -->\n                <div class=\"group relative p-8 rounded-2xl bg-neutral-900/40 border border-neutral-800 hover:border-brand-500/30 transition-all duration-300 ease-in-out overflow-hidden\">\n                    <div class=\"relative z-10\">\n                        <div class=\"w-12 h-12 rounded-lg bg-neutral-900 flex items-center justify-center mb-8 text-white border border-neutral-800 group-hover:border-brand-500/50 transition-colors\">\n                            <span class=\"iconify text-brand-500\" data-icon=\"lucide:clock\" data-width=\"24\" data-stroke-width=\"1.5\"></span>\n                        </div>\n                        <h3 class=\"font-display text-[22px] font-semibold text-white mb-3 tracking-tight\">Accés 24h / 7 dies</h3>\n                        <p class=\"text-[15px] leading-relaxed text-neutral-400 mb-8\">\n                            Entrena quan vulguis. El nostre sistema d'accés biomètric et permet entrar al gimnàs a qualsevol hora.\n                        </p>\n                        <ul class=\"space-y-3\">\n                            <li class=\"flex items-center gap-3 text-[14px] text-neutral-500\">\n                                <span class=\"iconify text-brand-500\" data-icon=\"lucide:check\" data-width=\"16\"></span>\n                                Accés il·limitat\n                            </li>\n                            <li class=\"flex items-center gap-3 text-[14px] text-neutral-500\">\n                                <span class=\"iconify text-brand-500\" data-icon=\"lucide:check\" data-width=\"16\"></span>\n                                Seguretat 24h\n                            </li>\n                        </ul>\n                    </div>\n                </div>\n\n                <!-- Service 2 -->\n                <div class=\"group relative p-8 rounded-2xl bg-neutral-900/40 border border-neutral-800 hover:border-brand-500/30 transition-all duration-300 ease-in-out overflow-hidden\">\n                    <div class=\"relative z-10\">\n                        <div class=\"w-12 h-12 rounded-lg bg-neutral-900 flex items-center justify-center mb-8 text-white border border-neutral-800 group-hover:border-brand-500/50 transition-colors\">\n                            <span class=\"iconify text-brand-500\" data-icon=\"lucide:users\" data-width=\"24\" data-stroke-width=\"1.5\"></span>\n                        </div>\n                        <h3 class=\"font-display text-[22px] font-semibold text-white mb-3 tracking-tight\">Entrenador Personal</h3>\n                        <p class=\"text-[15px] leading-relaxed text-neutral-400 mb-8\">\n                            Plans a mida dissenyats pels nostres experts per assolir els teus objectius de forma eficient.\n                        </p>\n                        <ul class=\"space-y-3\">\n                            <li class=\"flex items-center gap-3 text-[14px] text-neutral-500\">\n                                <span class=\"iconify text-brand-500\" data-icon=\"lucide:check\" data-width=\"16\"></span>\n                                Plans nutricionals\n                            </li>\n                            <li class=\"flex items-center gap-3 text-[14px] text-neutral-500\">\n                                <span class=\"iconify text-brand-500\" data-icon=\"lucide:check\" data-width=\"16\"></span>\n                                Seguiment mensual\n                            </li>\n                        </ul>\n                    </div>\n                </div>\n\n                <!-- Service 3 -->\n                <div class=\"group relative p-8 rounded-2xl bg-neutral-900/40 border border-neutral-800 hover:border-brand-500/30 transition-all duration-300 ease-in-out overflow-hidden\">\n                    <div class=\"relative z-10\">\n                        <div class=\"w-12 h-12 rounded-lg bg-neutral-900 flex items-center justify-center mb-8 text-white border border-neutral-800 group-hover:border-brand-500/50 transition-colors\">\n                            <span class=\"iconify text-brand-500\" data-icon=\"lucide:shopping-bag\" data-width=\"24\" data-stroke-width=\"1.5\"></span>\n                        </div>\n                        <h3 class=\"font-display text-[22px] font-semibold text-white mb-3 tracking-tight\">Botiga Pro</h3>\n                        <p class=\"text-[15px] leading-relaxed text-neutral-400 mb-8\">\n                            Suplementació esportiva de primera qualitat i equipament per al teu gimnàs domèstic.\n                        </p>\n                        <ul class=\"space-y-3\">\n                            <li class=\"flex items-center gap-3 text-[14px] text-neutral-500\">\n                                <span class=\"iconify text-brand-500\" data-icon=\"lucide:check\" data-width=\"16\"></span>\n                                Proteïna i Creatina\n                            </li>\n                            <li class=\"flex items-center gap-3 text-[14px] text-neutral-500\">\n                                <span class=\"iconify text-brand-500\" data-icon=\"lucide:check\" data-width=\"16\"></span>\n                                Assessorament inclòs\n                            </li>\n                        </ul>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Gallery -->\n    <section id=\"instalacions\" class=\"py-12 border-y border-neutral-800 bg-neutral-900/20\">\n        <div class=\"max-w-7xl mx-auto px-6\">\n            <div class=\"flex items-center justify-between mb-8\">\n                <h3 class=\"font-display text-[24px] font-semibold text-white tracking-tight\">Les nostres instal·lacions</h3>\n                <span class=\"text-[12px] text-brand-500 font-mono flex items-center gap-2\">\n                    <span class=\"relative flex h-2 w-2\">\n                        <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-500 opacity-75\"></span>\n                        <span class=\"relative inline-flex rounded-full h-2 w-2 bg-brand-500\"></span>\n                    </span>\n                    LIVE\n                </span>\n            </div>\n            <div class=\"grid grid-cols-1 md:grid-cols-4 gap-4 h-[400px]\">\n                <!-- Large Image -->\n                <div class=\"md:col-span-2 relative group rounded-xl overflow-hidden border border-neutral-800 h-full\">\n                    <img src=\"https://images.unsplash.com/photo-1593079831268-3381b0db4a77?q=80&w=2069&auto=format&fit=crop\" alt=\"Zona de Pes Lliure\" class=\"absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-105 opacity-80 group-hover:opacity-100\">\n                    <div class=\"absolute inset-0 bg-neutral-950/40 group-hover:bg-neutral-950/20 transition-colors\"></div>\n                    <div class=\"absolute bottom-6 left-6\">\n                        <span class=\"text-white text-[16px] font-semibold tracking-tight block mb-1\">Zona de Pes Lliure</span>\n                        <p class=\"text-neutral-300 text-[12px]\">Equipament Olímpic</p>\n                    </div>\n                </div>\n                <!-- Stacked Images -->\n                <div class=\"md:col-span-1 flex flex-col gap-4 h-full\">\n                    <div class=\"relative group rounded-xl overflow-hidden border border-neutral-800 flex-1\">\n                        <img src=\"https://images.unsplash.com/photo-1576678927484-cc907957088c?q=80&w=2069&auto=format&fit=crop\" alt=\"Zona Cardio\" class=\"absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-105 opacity-80 group-hover:opacity-100\">\n                        <div class=\"absolute inset-0 bg-neutral-950/40 group-hover:bg-neutral-950/20 transition-colors\"></div>\n                        <div class=\"absolute bottom-6 left-6\">\n                            <span class=\"text-white text-[16px] font-semibold tracking-tight\">Cardio Connectat</span>\n                        </div>\n                    </div>\n                    <div class=\"relative group rounded-xl overflow-hidden border border-neutral-800 flex-1\">\n                        <img src=\"https://images.unsplash.com/photo-1517836357463-d25dfeac3438?q=80&w=2070&auto=format&fit=crop\" alt=\"Entrenament Funcional\" class=\"absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-105 opacity-80 group-hover:opacity-100\">\n                        <div class=\"absolute inset-0 bg-neutral-950/40 group-hover:bg-neutral-950/20 transition-colors\"></div>\n                        <div class=\"absolute bottom-6 left-6\">\n                            <span class=\"text-white text-[16px] font-semibold tracking-tight\">Zona Funcional</span>\n                        </div>\n                    </div>\n                </div>\n                <!-- Last Image -->\n                <div class=\"md:col-span-1 relative group rounded-xl overflow-hidden border border-neutral-800 h-full\">\n                    <img src=\"https://images.unsplash.com/photo-1540497077202-7c8a33801524?q=80&w=2070&auto=format&fit=crop\" alt=\"Vestuaris\" class=\"absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-105 opacity-80 group-hover:opacity-100\">\n                    <div class=\"absolute inset-0 bg-neutral-950/40 group-hover:bg-neutral-950/20 transition-colors\"></div>\n                    <div class=\"absolute bottom-6 left-6\">\n                        <span class=\"text-white text-[16px] font-semibold tracking-tight block mb-1\">Vestuaris Premium</span>\n                        <p class=\"text-neutral-300 text-[12px]\">Taquilles i Dutxes</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Process / Stats -->\n    <section class=\"py-24 border-y border-neutral-800 bg-neutral-900/10\">\n        <div class=\"max-w-7xl mx-auto px-6\">\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-16 items-center\">\n                <div>\n                    <h2 class=\"font-display text-[32px] md:text-[40px] font-semibold text-white tracking-tight mb-6 leading-tight\">Sense matrícula,<br>sense permanència.</h2>\n                    <p class=\"text-neutral-400 mb-8 leading-relaxed text-[16px]\">\n                        Entenem que el teu estil de vida necessita flexibilitat. El procés d'alta és digital, ràpid i transparent.\n                    </p>\n                    \n                    <div class=\"space-y-8\">\n                        <!-- Step 1 -->\n                        <div class=\"flex gap-5\">\n                            <div class=\"flex-none flex flex-col items-center\">\n                                <div class=\"w-8 h-8 rounded-full border border-brand-500/50 text-brand-500 flex items-center justify-center text-[12px] font-bold bg-brand-500/10 shadow-[0_0_15px_rgba(217,70,239,0.3